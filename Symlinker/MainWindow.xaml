<mah:MetroWindow x:Class="Symlinker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Symlinker"
        Width="520" Height="490"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="icon.ico"
        TitleCharacterCasing="Normal"
        BorderThickness="0"
        GlowBrush="Transparent"
        NonActiveGlowBrush="Transparent"
        WindowTitleBrush="{DynamicResource MahApps.Brushes.ThemeBackground}"
        NonActiveWindowTitleBrush="{DynamicResource MahApps.Brushes.ThemeBackground}"
        TitleForeground="{DynamicResource MahApps.Brushes.ThemeForeground}"
        ShowIconOnTitleBar="False"
        TitleBarHeight="32"
        TitleAlignment="Stretch"
        OverrideDefaultWindowCommandsBrush="{DynamicResource MahApps.Brushes.ThemeForeground}">

    <mah:MetroWindow.TitleTemplate>
        <DataTemplate>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left"
                        Margin="14,0,0,0">
                <Image Source="icon.ico" Width="16" Height="16" Margin="0,0,8,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
            </StackPanel>
        </DataTemplate>
    </mah:MetroWindow.TitleTemplate>

    <Window.Resources>
        <!-- WinUI 3 corner radius -->
        <CornerRadius x:Key="ControlRadius">4</CornerRadius>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Subtle separator -->
        <Style x:Key="SectionSeparator" TargetType="Separator">
            <Setter Property="Margin" Value="0,6,0,14"/>
            <Setter Property="Opacity" Value="0.15"/>
        </Style>

        <!-- WinUI-style TextBox: filled background, subtle bottom border, accent on focus -->
        <Style TargetType="TextBox" BasedOn="{StaticResource MahApps.Styles.TextBox}">
            <Setter Property="mah:ControlsHelper.CornerRadius" Value="{StaticResource ControlRadius}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray8}"/>
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray9}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="mah:TextBoxHelper.WatermarkAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- WinUI-style ComboBox: filled background, subtle bottom border -->
        <Style TargetType="ComboBox" BasedOn="{StaticResource MahApps.Styles.ComboBox}">
            <Setter Property="mah:ControlsHelper.CornerRadius" Value="{StaticResource ControlRadius}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Gray8}"/>
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray9}"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- Rounded accent button -->
        <Style x:Key="RoundedAccentButton" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square.Accent}">
            <Setter Property="mah:ControlsHelper.CornerRadius" Value="{StaticResource ControlRadius}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,6"/>
        </Style>

        <!-- Info button: same fill as controls -->
        <Style x:Key="RoundedFlatButton" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button}">
            <Setter Property="mah:ControlsHelper.CornerRadius" Value="{StaticResource ControlRadius}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray9}"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Row 0: Type selector -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Symlink Type" Style="{StaticResource SectionHeader}" />
            <ComboBox x:Name="typeSelectorComboBox"
                      SelectionChanged="TypeSelectorComboBox_SelectionChanged"
                      ToolTipService.ShowDuration="10000">
                <ComboBoxItem Content="Folder symbolic link" />
                <ComboBoxItem Content="File symbolic link" />
            </ComboBox>
            <Separator Style="{StaticResource SectionSeparator}" />
        </StackPanel>

        <!-- Row 1: Link location + name -->
        <StackPanel Grid.Row="1">
            <TextBlock x:Name="groupBox1Header" Text="Link Folder" Style="{StaticResource SectionHeader}" />

            <TextBlock x:Name="label1"
                       Text="Select the location for your link:"
                       FontSize="12" Margin="0,0,0,6" />

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="linkLocationTextBox"
                         AllowDrop="True"
                         mah:TextBoxHelper.Watermark="Path to link location..."
                         PreviewDragEnter="TextBox_PreviewDragEnter"
                         PreviewDragOver="TextBox_DragOver"
                         Drop="TextBox_Drop"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Browse"
                        Click="ExploreButton1_Click"
                        Style="{StaticResource RoundedAccentButton}"
                        Width="80" />
            </Grid>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="label2"
                           Text="Link name:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           FontSize="12"
                           Margin="0,0,10,0" />
                <TextBox Grid.Column="1" x:Name="linkNameTextBox"
                         mah:TextBoxHelper.Watermark="Name for the link..." />
            </Grid>

            <Separator Style="{StaticResource SectionSeparator}" />
        </StackPanel>

        <!-- Row 2: Destination + link type -->
        <StackPanel Grid.Row="2">
            <TextBlock x:Name="groupBox2Header" Text="Destination Folder" Style="{StaticResource SectionHeader}" />

            <TextBlock x:Name="label3"
                       Text="Select the path to the real folder you want to link:"
                       FontSize="12" Margin="0,0,0,6" />

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="destinationLocationTextBox"
                         AllowDrop="True"
                         mah:TextBoxHelper.Watermark="Path to destination..."
                         PreviewDragEnter="TextBox_PreviewDragEnter"
                         PreviewDragOver="TextBox_DragOver"
                         Drop="TextBox_Drop"
                         Margin="0,0,8,0" />
                <Button Grid.Column="1" Content="Browse"
                        Click="ExploreButton2_Click"
                        Style="{StaticResource RoundedAccentButton}"
                        Width="80" />
            </Grid>

            <StackPanel Margin="0,0,0,4">
                <TextBlock Text="Link type:"
                           Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                           FontSize="12"
                           Margin="0,0,0,6" />
                <ComboBox x:Name="linkTypeComboBox"
                          ToolTipService.ShowDuration="10000">
                    <ComboBoxItem Content="Symbolic Link" />
                    <ComboBoxItem Content="Hard Link" />
                    <ComboBoxItem Content="Directory Junction" />
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <!-- Row 4: About + Create Link -->
        <Grid Grid.Row="4" VerticalAlignment="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="AboutButton_Click"
                    Style="{StaticResource RoundedFlatButton}"
                    ToolTip="About Symlinker"
                    VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="InformationOutline" Width="18" Height="18"
                                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" />
            </Button>

            <Button Grid.Column="2" x:Name="createLinkButton"
                    Click="CreateLink_Click"
                    Style="{StaticResource RoundedAccentButton}"
                    Padding="18,8"
                    FontSize="13">
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="ShieldOutline" Width="16" Height="16"
                                               Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Create Link" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</mah:MetroWindow>
